{
  "name": "jet-script",
  "version": "2.0.0",
  "description": "Standalone short video editing workspace for external distribution",
  "scripts": {
    "all": "tsx scripts/video_edit.ts --profile=short --to-step=render --no-title",
    "all:title": "tsx scripts/video_edit.ts --profile=short --title=\"${VIDEO_TITLE:-ここにタイトル}\"",
    "video-edit": "tsx scripts/video_edit.ts --profile=short --to-step=render --no-title",
    "video-edit-title": "tsx scripts/video_edit.ts --profile=short --title=\"${VIDEO_TITLE:-ここにタイトル}\"",
    "transcribe": "tsx scripts/video_edit.ts --profile=short --to-step=transcribe --no-title",
    "render": "tsx scripts/video_edit.ts --profile=short --from-step=render --to-step=render --no-title",
    "base-video": "tsx scripts/base-video.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.296",
    "@remotion/renderer": "^4.0.296",
    "dotenv": "^17.2.3",
    "openai": "^6.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.296"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
